# ==========================================
# DATABASE CONFIGURATION
# ==========================================

# OPTION 1: Local Postgres (Docker) - Default
# To use Local, keep these uncommented and DATABASE_URL commented out.
POSTGRES_HOST=localhost
# POSTGRES_HOST=postgres
# DOCKER_POSTGRES_HOST=remote.db.host
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=biwenger
POSTGRES_PORT=5432

# OPTION 2: Supabase / Remote Postgres
# To use Supabase, uncomment DATABASE_URL and comment out the Local variables above.
# This takes precedence over the individual variables above if set.
# DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:[PORT]/[DB]"

# ==========================================
# BIWENGER API CREDENTIALS
# ==========================================
# This token is used for background data syncing (market, results, etc.).
# Individual manager tokens for automation (Auto-Align) are stored in the database (users table).
BIWENGER_TOKEN=your_token_here
BIWENGER_LEAGUE_ID=your_league_id_here
BIWENGER_USER_ID=your_user_id_here

# ==========================================
# APPLICATION AUTH
# ==========================================
# Random string for session encryption (generate with `openssl rand -base64 32`)
AUTH_SECRET="your_random_secret_string"

# ==========================================
# EUROLEAGUE CONFIG
# ==========================================
EUROLEAGUE_SEASON_CODE=E2025
LEAGUE_START_DATE=2025-09-25
